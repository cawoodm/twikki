{
  "type": "module",
  "name": "twikki",
  "version": "0.24.0",
  "description": "TiddlyWiki-Inspired Information Platform",
  "scripts": {
    "dev": "vite",
    "test": "node --test --watch ./tests/unit/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "compile": "node vite-plugin-tiddler-compile.js",
    "watch": "npm-watch",
    "run": "vite --port 8081 --strict-port",
    "build": "vite build --emptyOutDir && cd dist && vite",
    "build-test": "vite build --emptyOutDir && cd dist && vite --open --host",
    "publish": "pwsh ci/publish.ps1"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@playwright/test": "^1.48.0",
    "@eslint/js": "^9.9.1",
    "eslint-config-strongloop": "^2.1.0",
    "globals": "^15.9.0",
    "vite": "^5.4.2"
  },
  "author": "Marc Cawood",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cawoodm/twikki/issues"
  },
  "homepage": "https://cawoodm.github.io/twikki",
  "main": "boot.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cawoodm/twikki.git"
  }
}