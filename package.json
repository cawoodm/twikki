{
  "type": "module",
  "name": "twikki",
  "version": "0.28.0",
  "description": "TiddlyWiki-Inspired Information Platform",
  "scripts": {
    "dev": "vite",
    "test": "node --test --test-force-exit --watch ./test/unit/*.test.js",
    "test:unit": "node --test --test-force-exit ./test/unit/*.test.js",
    "test:e2e": "npm run compile && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "compile": "node vite-plugin-tiddler-compile.js",
    "watch": "npm-watch",
    "run": "vite --port 8081 --strict-port",
    "build": "vite build --emptyOutDir && cd dist && vite",
    "build-test": "vite build --emptyOutDir && cd dist && vite --open --host",
    "publish": "pwsh ci/publish.ps1",
    "docker:build": "docker build -t twikki .",
    "docker:run": "docker run --rm -d -p 8081:80 --name twikki twikki",
    "docker": "npm run docker:build && npm run docker:run && start http://localhost:8081"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.48.0",
    "eslint-config-strongloop": "^2.1.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.9.0",
    "vite": "^5.4.2",
    "workbox-cli": "^7.4.1"
  },
  "author": "Marc Cawood",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cawoodm/twikki/issues"
  },
  "homepage": "https://cawoodm.github.io/twikki",
  "main": "boot.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cawoodm/twikki.git"
  }
}
