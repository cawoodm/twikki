      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/vite-plugin-tiddler-compile.js"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}