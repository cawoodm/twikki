{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "*** DEV",
      "windows": {
        "command": "${workspaceFolder}/ci/dev.cmd"
      },
      "linux": {
        "command": "${workspaceFolder}/ci/dev.sh"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "*** PUBLISH",
      "windows": {
        "command": "${workspaceFolder}/ci/publish.cmd"
      },
      "linux": {
        "command": "${workspaceFolder}/ci/publish.sh"
      },
      "problemMatcher": []
    },
    {
